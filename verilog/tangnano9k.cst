// Minimal Tang Nano 9K Constraints
// Removing IO_TYPE and DRIVE to let IDE use defaults
// This solves potential bank voltage conflicts

// Clock
IO_LOC "clk_27mhz" 52;

// Reset Button
IO_LOC "btn_rst" 4;

// 6 LEDs - Only Locations
IO_LOC "led[0]" 10;
IO_LOC "led[1]" 11;
IO_LOC "led[2]" 13;
IO_LOC "led[3]" 14;
IO_LOC "led[4]" 15;
IO_LOC "led[5]" 16;
